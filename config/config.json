  "binance": {
    "ws_base_url"       : "wss://stream.binance.com:9443/stream",
    "rest_base_url"     : "https://api.binance.com",
    "buffer_capacity"   : 500,
    "stale_threshold_s" : 30,
    "max_retries"       : 10,
    "initial_delay_s"   : 1,
    "backoff_multiplier": 2,
    "max_delay_s"       : 60
