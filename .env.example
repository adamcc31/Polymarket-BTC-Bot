# ============================================================
# Polymarket Bot — Environment Variables Template
# Copy to .env and fill in actual values. NEVER commit .env!
# ============================================================

# --- Binance (READ-ONLY permission sufficient) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# --- Polymarket Wallet ---
# Private key wallet Polygon Anda (akun yang sama dengan Polymarket).
# Digunakan oleh py-clob-client untuk men-derive CLOB API credentials
# secara otomatis via createOrDeriveApiKey().
# Format: 0x... (hex, tanpa prefix jika menggunakan py-clob-client)
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here

# --- Polymarket Builder API Keys (untuk Gasless Relayer) ---
# Dibuat di: https://polymarket.com/settings?tab=builder
# Digunakan HANYA untuk operasi on-chain gasless (approve, redeem).
# BUKAN untuk trading CLOB — trading credentials di-derive dari private key.
# 3 nilai: key, secret, passphrase (secret & passphrase hanya ditampilkan 1x!)
POLY_BUILDER_API_KEY=your_builder_key_here
POLY_BUILDER_SECRET=your_builder_secret_here
POLY_BUILDER_PASSPHRASE=your_builder_passphrase_here

# --- Database ---
# If not set → SQLite (local: ./data/trading.db)
# If set → PostgreSQL (Railway: injected automatically)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Operation Mode ---
LIVE_MODE=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Railway Static Proxy (REQUIRED for Binance API IP whitelist) ---
# QUOTAGUARD_URL=http://user:pass@proxy.quotaguard.com:9293
